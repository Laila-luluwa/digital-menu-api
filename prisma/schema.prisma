generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}

model MenuItem {
  id           Int    @id @default(autoincrement())
  name         String
  price        Float
  quantity     Int
  restaurantId Int
}