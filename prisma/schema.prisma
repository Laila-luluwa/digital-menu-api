generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  KITCHEN
}

enum OrderStatus {
  QUEUED
  COOKING
  READY
  SERVED
}

enum SessionStatus {
  ACTIVE
  EXPIRED
}

model Restaurant {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  menuItems MenuItem[]
  menuCategories MenuCategory[]
  tables    Table[]
  users     User[]
  orders    Order[]
  tags      Tag[]
  restaurantUsers RestaurantUser[]
}

model MenuCategory {
  id           Int         @id @default(autoincrement())
  name         String
  restaurantId Int
  description  String?
  displayOrder Int         @default(0)
  createdAt    DateTime    @default(now())

  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItem[]

  @@unique([restaurantId, name])
}

model MenuItem {
  id           Int         @id @default(autoincrement())
  name         String
  description  String?
  price        Float
  quantity     Int
  restaurantId Int
  categoryId   Int?

  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  category     MenuCategory? @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
  inventory    Inventory?
  tags         MenuItemTag[]
}

model Table {
  id           Int      @id @default(autoincrement())
  tableCode    String
  restaurantId Int

  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  sessions     TableSession[]

  @@unique([restaurantId, tableCode])
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  password     String
  role         Role
  restaurantId Int
  createdAt    DateTime @default(now())

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantUsers RestaurantUser[]
}

model Order {
  id           Int         @id @default(autoincrement())
  tableCode    String
  restaurantId Int
  totalPrice   Float       @default(0)
  status       OrderStatus @default(QUEUED)
  createdAt    DateTime    @default(now())

  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  items        OrderItem[]
  sessionId    Int
  session      TableSession @relation(fields: [sessionId], references: [id])
}

model OrderItem {
  id            Int      @id @default(autoincrement())
  orderId       Int
  menuItemId    Int
  quantity      Int
  priceSnapshot Float

  order         Order    @relation(fields: [orderId], references: [id])
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id])
}

model TableSession {
  id        Int          @id @default(autoincrement())
  tableId   Int
  table     Table        @relation(fields: [tableId], references: [id])
  token     String       @unique @default(uuid())
  createdAt DateTime     @default(now())
  expiresAt DateTime
  status    SessionStatus @default(ACTIVE)

  orders    Order[]
}

model RestaurantUser {
  id           Int  @id @default(autoincrement())
  restaurantId Int
  userId       Int
  role         Role
  createdAt    DateTime @default(now())

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([restaurantId, userId])
}

model Tag {
  id           Int    @id @default(autoincrement())
  name         String
  restaurantId Int

  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItemTag[]

  @@unique([restaurantId, name])
}

model MenuItemTag {
  id        Int @id @default(autoincrement())
  menuItemId Int
  tagId     Int

  menuItem  MenuItem @relation(fields: [menuItemId], references: [id])
  tag       Tag      @relation(fields: [tagId], references: [id])

  @@unique([menuItemId, tagId])
}

model Inventory {
  id                Int @id @default(autoincrement())
  menuItemId        Int @unique
  quantityAvailable Int
  updatedAt         DateTime @updatedAt

  menuItem          MenuItem @relation(fields: [menuItemId], references: [id])
}
